# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager lock files (pnpm uses pnpm-lock.yaml)
package-lock.json

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# OCR tools (scripts directory only)
scripts/venv/
scripts/ocr_results/

# Python virtual environments
venv/
env/
.venv/
api_venv/
notebooks/venv/

# Legacy directories - 予測に必要なため除外しない
# api/
# core/

# Test data (too large)
test_extreme_cube.json/

# CUBE data (analysis purposes only, too many files for Git)
data/extreme_cubes/
data/analysis/

# Training data files (too large for Git, ~6GB total)
data/training_data/

# ==============================================================================
# 巨大ファイル防止ルール（デプロイ時間短縮のため必須）
# ==============================================================================

# すべての.pklファイルを禁止（巨大になりがち）
*.pkl

# Python仮想環境（すべての場所）
**/venv/
**/.venv/
**/env/
api_venv/
scripts/venv_onnx/

# 学習・分析データ
data/models/*_data.pkl
data/models/backup/
data/models/combination_batches/
data/models/combination_checkpoint.pkl
data/models/evaluation_results*.pkl
data/training_data/
data/base_statistics/

# Python キャッシュ
__pycache__/
*.pyc

# その他
.playwright-mcp/
*.backup

# Git debug logs
git_push_debug*.log

# ==============================================================================
# 本番環境に必要なファイル（これらは除外しない）
# ==============================================================================
# ✅ data/models/*.onnx - ONNXモデル（軽量）
# ✅ data/models/*_lgb.txt - LightGBMモデル（テキスト形式）
# ✅ data/models/*_keys.json - 特徴量キー
# ✅ data/past_results.csv - 過去データ
# ✅ data/keisen_master.json - 罫線マスタ
# ==============================================================================
