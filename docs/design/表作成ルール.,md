## 11. 付録: 擬似コード

```
function generateChart(sourceList, pattern):
  // pattern: 'A1' | 'A2' | 'B1' | 'B2'
  nums = applyPatternExpansion(sourceList, pattern) // §3
  mainRows = buildMainRows(nums)                    // §4
  rows = mainRows.length * 2  // 最大8行（0-indexedでは0-7）
  cols = 8
  grid = make(rows, cols, null)

  // 初期配置 §5（奇数行の奇数列にメイン行を配置）
  for i in 0..mainRows.length-1:
    let row = i*2 + 1  // 1, 3, 5, 7行目（1-indexed）
    for j in 0..mainRows[i].length-1:  // メイン行の要素数分だけ配置（最大4要素）
      let col = j*2 + 1  // 1, 3, 5, 7列目（1-indexed）
      grid[row][col] = mainRows[i][j]

  // メイン行配置後の余りマスルール §5（裏数字適用前）
  applyMainRowRemainingCopy(grid, rows, cols)
  // 奇数行の空の奇数列・偶数列に対して、その上のメイン行の同じ列の数字をコピー

  // パターンA2/B2の場合のみ中心0配置 §5
  if pattern == 'A2' or pattern == 'B2':
    placeCenterZeroIfEmpty(grid)

  // 縦パス §6.1（収束）
  // 上から下へ順に処理し、nullかつ上に値がある場合に裏数字を配置
  while true:
    updated = false
    for y in 1..rows-1:  // 行1から開始（0-indexedでは1行目から）
      for x in 0..cols-1:
        if grid[y][x] is null and grid[y-1][x] != null:
          grid[y][x] = inverse(grid[y-1][x])
          updated = true
    if not updated: break

  // 横パス §6.2（収束）
  while true:
    updated = false
    for y in 1..rows-1:  // 行1から開始（0-indexedでは1行目から）
      for x in 0..cols-1:
        if grid[y][x] is null and x>0 and grid[y][x-1] != null:
          grid[y][x] = inverse(grid[y][x-1])
          updated = true
    if not updated: break

  // 余りマス §7（収束）
  while true:
    updated = false
    for y in 1..rows-1:  // 行1から開始（0-indexedでは1行目から）
      for x in 0..cols-1:
        if grid[y][x] is null and grid[y-1][x] != null:
          grid[y][x] = grid[y-1][x]
          updated = true
    if not updated: break

  return grid
```

