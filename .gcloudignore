# .gcloudignore
# Cloud Buildでアップロードするファイルを制御

# Python関連
venv/
api/venv/
notebooks/venv/
scripts/venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Node関連
node_modules/
.next/
.pnpm-store/

# IDE関連
.vscode/
.idea/
*.swp
*.swo

# 環境変数
.env*
!.env.local.example

# データファイル（大きい場合は除外する可能性あり）
# data/models/*.pkl  # 必要に応じてコメントアウト
# 注意: data/ディレクトリはDockerイメージに含まれる必要があるため、除外しない

# Git関連
.git/
.gitignore

# ドキュメント（必要に応じて）
docs/
*.md
!README.md

# その他
.DS_Store
*.log
vercel.json
.vercel/

