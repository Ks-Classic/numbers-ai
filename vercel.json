{
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "framework": "nextjs",
    "outputDirectory": ".next",
    "functions": {
        "api/py/**/*.py": {
            "memory": 1024,
            "maxDuration": 30,
            "includeFiles": "core/**,data/models/*.onnx,data/models/*.json,data/keisen_master.json,data/past_results.csv,api/py/**/libgomp.so.1"
        }
    },
    "env": {
        "LD_LIBRARY_PATH": "/var/task/api/py"
    },
    "rewrites": [
        {
            "source": "/api/py/:path*",
            "destination": "/api/py/:path*"
        }
    ]
}