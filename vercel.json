{
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "framework": "nextjs",
    "outputDirectory": ".next",
    "functions": {
        "api/py/**/*.py": {
            "memory": 1024,
            "maxDuration": 30,
            "includeFiles": "core/**,data/**,api/py/**/libgomp.so.1"
        }
    },
    "rewrites": [
        {
            "source": "/api/py/:path*",
            "destination": "/api/py/:path*"
        }
    ]
}